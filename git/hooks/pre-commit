#!/usr/bin/env bash

set -euo pipefail

while IFS= read -r -d '' path; do
  case "$path" in
    .DS_Store|*/.DS_Store)
      echo "error: refusing to commit .DS_Store files" >&2
      echo "hint: remove them from the index with: git rm --cached -- .DS_Store '**/.DS_Store'" >&2
      exit 1
      ;;
  esac
done < <(git diff --cached --name-only -z --diff-filter=ACMR)
